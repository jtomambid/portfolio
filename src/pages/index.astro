---
import Hero from '../components/Hero';
import About from '../components/About';
import Skills from '../components/Skills';
import Experience from '../components/Experience';
import Projects from '../components/Projects';
import Contact from '../components/Contact';
import { personal, skills, experience, education, projects } from '../data/portfolio';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={`${personal.name} — ${personal.roles[0]}`} />
  <meta name="author" content={personal.name} />
  <meta property="og:title" content={personal.name} />
  <meta property="og:description" content={`${personal.roles[0]} based in ${personal.location}`} />
  <meta property="og:type" content="website" />
  <title>{personal.name}</title>
</head>

<body class="bg-canvas text-ink font-sans">

  <!-- ─── Navigation ───────────────────────────────────── -->
  <nav
    id="nav"
    class="fixed inset-x-0 top-0 z-50 transition-all duration-300"
  >
    <div class="max-w-6xl mx-auto px-6 md:px-10 flex items-center justify-between h-16">

      <!-- Logo / avatar -->
      <a href="/" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-full bg-accent-pale flex items-center justify-center text-accent text-xs font-bold border border-accent/20 flex-shrink-0">
          JT
        </div>
        <span class="font-serif font-semibold text-ink text-base">James Tomambid</span>
      </a>

      <!-- Links -->
      <div class="flex items-center gap-1 md:gap-1.5">
        <a href="#about"      class="hidden sm:block text-muted text-sm font-medium px-3 py-1.5 rounded-full hover:text-ink transition-colors duration-200">About</a>
        <a href="#experience" class="hidden sm:block text-muted text-sm font-medium px-3 py-1.5 rounded-full hover:text-ink transition-colors duration-200">Experience</a>
        <a href="#work"       class="hidden sm:block text-muted text-sm font-medium px-3 py-1.5 rounded-full hover:text-ink transition-colors duration-200">Work</a>
        <a
          href="#contact"
          class="ml-2 bg-ink text-white text-xs font-semibold px-4 py-2 rounded-full transition-all duration-200 hover:bg-ink/80"
        >
          Open to Work
        </a>
      </div>

    </div>
  </nav>

  <!-- Scroll border activation -->
  <script>
    const nav = document.getElementById('nav');
    let ticking = false;
    function updateNav() {
      if (!nav) return;
      if (window.scrollY > 40) {
        nav.style.background = 'rgba(250, 250, 249, 0.88)';
        nav.style.backdropFilter = 'blur(16px)';
        nav.style.webkitBackdropFilter = 'blur(16px)';
        nav.style.borderBottom = '1px solid #E5E4E1';
      } else {
        nav.style.background = 'transparent';
        nav.style.backdropFilter = 'none';
        nav.style.webkitBackdropFilter = 'none';
        nav.style.borderBottom = '1px solid transparent';
      }
      ticking = false;
    }
    window.addEventListener('scroll', () => {
      if (!ticking) { requestAnimationFrame(updateNav); ticking = true; }
    }, { passive: true });
  </script>

  <!-- ─── Page content ─────────────────────────────────── -->
  <main>
    <Hero       client:load  personal={personal} />
    <About      client:load  personal={personal} />
    <Skills     client:load  skills={skills} />
    <Experience client:load  experience={experience} education={education} />
    <Projects   client:load  projects={projects} />
    <Contact    client:load  personal={personal} />
  </main>

  <!-- ─── Footer ───────────────────────────────────────── -->
  <footer class="border-t border-border py-8 px-6 md:px-10 max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-3">
    <span class="text-muted text-xs">© 2025 {personal.name}</span>
    <div class="flex items-center gap-5">
      <a
        href={`https://${personal.github}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted text-xs hover:text-ink transition-colors duration-200"
      >
        GitHub
      </a>
      <span class="w-1 h-1 rounded-full bg-border" aria-hidden="true"></span>
      <a
        href={`https://www.${personal.linkedin}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted text-xs hover:text-ink transition-colors duration-200"
      >
        LinkedIn
      </a>
      <span class="w-1 h-1 rounded-full bg-border" aria-hidden="true"></span>
      <a
        href={`mailto:${personal.email}`}
        class="text-muted text-xs hover:text-ink transition-colors duration-200"
      >
        Email
      </a>
    </div>
  </footer>

</body>
</html>
